# --- LLM provider ---
# Options: "ollama" (default, fully local) or "gemini" (optional Google AI API)
LDR_LLM_PROVIDER=ollama

# Ollama (local) settings
LDR_OLLAMA_BASE_URL=http://localhost:11434
LDR_OLLAMA_MODEL=qwen2.5:14b
LDR_OLLAMA_SUMMARIZER_MODEL=qwen2.5:7b
LDR_OLLAMA_NUM_CTX=32768

# Gemini (optional, only if LDR_LLM_PROVIDER=gemini)
GOOGLE_API_KEY=
LDR_GEMINI_MODEL=gemini-2.5-pro
LDR_GEMINI_SUMMARIZER_MODEL=gemini-2.5-flash

# --- Firecrawl (self-hosted) ---
LDR_FIRECRAWL_BASE_URL=http://localhost:3002
# Leave empty for self-hosted with no auth; set if your instance requires it.
LDR_FIRECRAWL_API_KEY=

# --- Agent budgets ---
LDR_MAX_ITERATIONS=20
LDR_MAX_SEARCH_RESULTS=8
LDR_TIME_LIMIT_MINUTES=15
LDR_PAGE_CHAR_LIMIT=20000
